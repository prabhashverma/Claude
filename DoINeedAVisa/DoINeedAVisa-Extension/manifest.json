{
  "manifest_version": 3,
  "name": "DoINeedAVisa",
  "version": "1.0.1",
  "description": "Check visa requirements directly on Google Flights",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.google.com/travel/flights*",
    "https://doineedavisa-api-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/travel/flights*"],
      "js": ["countries-data.js", "parse-flights.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
